---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section id="hero" class="section-card">
    <p class="eyebrow">Entry-Level Software Developer</p>
    <h1>Jared Street</h1>
    <p>
      I build practical web, database, and application projects using C#,
      ASP.NET Core, PHP, SQL, JavaScript, and Go.
    </p>
  </section>

  <section id="featured-projects">
    <p class="eyebrow">Selected Work</p>
    <h2>Featured Projects</h2>
    <p>Project cards will go here.</p>
  </section>

  <section id="skills">
    <p class="eyebrow">Technical Stack</p>
    <h2>Skills</h2>
    <p>Grouped skills will go here.</p>
  </section>

  <section id="contact">
    <p class="eyebrow">Contact</p>
    <h2>Get in Touch</h2>
    <p>Resume, GitHub, LinkedIn, and email links will go here.</p>
  </section>
</BaseLayout>