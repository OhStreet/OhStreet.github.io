---
import BaseLayout from "../../layouts/BaseLayout.astro";

const projectCategories = [
  {
    name: "C# / .NET",
    description: "Application and service projects built with C#, ASP.NET Core, MVC, Entity Framework, and WCF.",
    projects: [
      {
        title: "SportsPro Technical Support",
        href: "/projects/sportspro/",
        sourceHref: "https://github.com/OhStreet/SportsPro-Technical-Support",
        summary: "ASP.NET Core MVC support management system with database-backed CRUD workflows.",
        tech: ["C#", "ASP.NET Core MVC", "Entity Framework", "SQL Server"],
        image: "/screenshots/sportspro-home.png",
        imageAlt: "SportsPro Technical Support home page",
      },
      {
        title: "WCF Service Project",
        href: "/projects/wcf/",
        sourceHref: "https://github.com/OhStreet/WCF-Library-Record-System",
        summary: "Service/client project demonstrating C# service methods and structured communication.",
        tech: ["C#", "WCF", ".NET Framework", "SOAP"],
        image: "/screenshots/library-wcf-service-browser.png",
        imageAlt: "Library WCF service running in browser",
      },
    ],
  },
  {
    name: "PHP / MySQL",
    description: "Database-backed web applications and REST-style services built with PHP, MySQL, JSON, and AJAX.",
    projects: [
      {
        title: "Simple Forum Application",
        href: "/projects/simple-forum/",
        sourceHref: "https://github.com/OhStreet/Simple-Forum",
        summary: "Dynamic forum application with users, posts, categories, sessions, and database persistence.",
        tech: ["PHP", "MySQL", "PDO", "Sessions"],
        image: "/screenshots/simple-forum-home.png",
        imageAlt: "Simple Forum home page",
      },
      {
        title: "RESTful Student Contacts Service",
        href: "/projects/rest-ajax-php/",
        sourceHref: "https://github.com/OhStreet/RESTful-Student-Contacts-Service",
        summary: "PHP/MySQL service that returns JSON data and is consumed by an AJAX client.",
        tech: ["PHP", "MySQL", "AJAX", "JSON"],
        image: "/screenshots/RESTful-AJAX-home.png",
        imageAlt: "RESTful Student Contacts Service home page",
      },
      {
        title: "Dark Souls CRUD Web Service",
        href: "/projects/crud-restful-service/",
        sourceHref: "https://github.com/CloneMalone/DarkSouls-PHP-AJAJ",
        summary: "Themed CRUD web service with PHP API endpoints, MySQL tables, and AJAX interactions.",
        tech: ["PHP", "MySQL", "JavaScript", "jQuery AJAX"],
        image: "/screenshots/darksouls-home.png",
        imageAlt: "Dark Souls CRUD web service home page",
      },
    ],
  },
  {
    name: "Go / CLI Tools",
    description: "Command-line tools and automation projects focused on practical desktop workflows.",
    projects: [
      {
        title: "Display Switching CLI",
        href: "/projects/display-switcher/",
        sourceHref: "https://github.com/OhStreet/DisplaySwitcher",
        summary: "Go command-line tool for switching Windows display profiles and launching workflow-specific apps.",
        tech: ["Go", "Cobra", "JSON", "Windows"],
        image: "/screenshots/display-switcher-show.png",
        imageAlt: "Display Switcher CLI home page",
      },
    ],
  },
  {
    name: "Game / C#",
    description: "Gameplay prototypes and interactive systems built with C# outside of traditional business applications.",
    projects: [
      {
        title: "Godot Grid Roguelike Prototype",
        href: "/projects/godot-roguelike/",
        sourceHref: "https://github.com/OhStreet/godot-roguelike-prototype",
        summary: "Turn-based grid roguelike prototype with combat, enemy turns, rewards, and persistent run state.",
        tech: ["Godot", "C#", "Game Systems", "Tilemaps"],
        image: "/screenshots/roguelike-combat-floor.png",
        imageAlt: "Godot Grid Roguelike Prototype home page",
      },
      {
        title: "Troll Pong Gamejam Entry",
        summary: "A game jam I participated in with 2 other people using mob programming methods. The theme of the game jam was WarioWare.",
        href: "https://severalherr.itch.io/troll-pong",
        sourceHref: "https://github.com/jherrflexion/sti-game-jam",
        image: "/screenshots/troll-pong.png",
        imageAlt: "Troll Pong gamejam entry",
        tech: ["Godot", "C#", "Game Systems"],
      }
    ],
  },
  {
    name: "JavaScript / Realtime",
    description: "Client-side and realtime projects using JavaScript and event-driven web behavior.",
    projects: [
    {
      title: "Realtime Voting System",
      href: "/projects/voting-system/",
      sourceHref: "https://github.com/OhStreet/Web-Socket-Real-Time-Voting-System",
      summary: "Realtime voting demo using browser-based interaction and live result updates.",
      tech: ["JavaScript", "Node.js", "Socket.IO", "HTML/CSS"],
      image: "/screenshots/realtime-voting-home.png",
      imageAlt: "Realtime voting application page",
    },
    ],
  },
];

const courseworkArchive = {
  title: "Coursework & Syllabi Archive",
  href: "/coursework/",
  summary:
    "An archive of CIS course syllabi and academic materials from Southeast Technical College.",
};
---

<BaseLayout
  title="Projects | Jared Street"
  description="Project library for Jared Street, organized by technology area and project type."
>
  <section class="page-hero fade-in">
    <p class="eyebrow">Project Library</p>
    <h1>Projects</h1>
    <p>
      A collection of web, database, application, service, CLI, and game projects.
    </p>
  </section>

  <section class="project-library fade-in" aria-labelledby="project-library-heading">
    <div class="section-heading">
      <p class="eyebrow">Browse by Category</p>
      <h2 id="project-library-heading">Explore Project Areas</h2>
      <p>
        Open a category to view related projects and jump to individual project documentation.
      </p>
    </div>

    <div class="category-grid">
      {projectCategories.map((category) => (
        <article class="category-card hover-category-card" data-category-card>
          <div class="category-card-header">
            <button
              class="category-card-toggle"
              type="button"
              data-category-toggle
              aria-expanded="false"
            >
              <span>
                <strong>{category.name}</strong>
                <small>
                  {category.projects.length} project{category.projects.length === 1 ? "" : "s"}
                </small>
              </span>

              <span class="category-card-icon" aria-hidden="true">+</span>
            </button>
          </div>

          <div class="category-card-body">
            <p>{category.description}</p>

          <div class="category-carousel" data-carousel>
            {category.projects.length > 1 && (
              <div class="carousel-controls">
                <button
                  class="carousel-button"
                  type="button"
                  data-carousel-prev
                  aria-label={`View previous ${category.name} project`}
                >
                  ←
                </button>

                <span class="carousel-count">
                  <span data-carousel-index>1</span> / {category.projects.length}
                </span>

                <button
                  class="carousel-button"
                  type="button"
                  data-carousel-next
                  aria-label={`View next ${category.name} project`}
                >
                  →
                </button>
              </div>
            )}

            <div class="category-project-window">
              {category.projects.map((project, index) => (
                <article
                  class={`project-slide ${index === 0 ? "is-active" : ""}`}
                  data-carousel-slide
                >
                  {project.image ? (
                    <img
                      class="project-slide-image"
                      src={project.image}
                      alt={project.imageAlt}
                    />
                  ) : (
                    <div class="project-image-placeholder">
                      Project documentation
                    </div>
                  )}

                  <div class="project-slide-content">
                    <h3>
                      <a href={project.href}>{project.title}</a>
                    </h3>

                    <p>{project.summary}</p>

                    <div class="tech-list">
                      {project.tech.map((techItem) => (
                        <span class="tech-pill">{techItem}</span>
                      ))}
                    </div>

                    <div class="project-link-row">
                      <a class="text-link" href={project.href}>
                        View Project
                      </a>

                      {project.sourceHref && (
                        <a
                          class="text-link"
                          href={project.sourceHref}
                          target="_blank"
                          rel="noopener noreferrer"
                        >
                          View Source
                        </a>
                      )}
                    </div>
                  </div>
                </article>
              ))}
            </div>
          </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-card coursework-callout fade-in" aria-labelledby="coursework-archive-heading">
    <div>
      <p class="eyebrow">Supporting Materials</p>
      <h2 id="coursework-archive-heading">{courseworkArchive.title}</h2>
      <p>{courseworkArchive.summary}</p>
    </div>

    <div class="coursework-callout-action">
      <a class="button button-secondary" href={courseworkArchive.href}>
        View Coursework Archive
      </a>
    </div>
</section>
</BaseLayout>
<script>
  document.querySelectorAll("[data-carousel]").forEach((carousel) => {
    const slides = Array.from(
      carousel.querySelectorAll("[data-carousel-slide]")
    );

    const previousButton = carousel.querySelector("[data-carousel-prev]");
    const nextButton = carousel.querySelector("[data-carousel-next]");
    const indexLabel = carousel.querySelector("[data-carousel-index]");

    if (slides.length === 0) return;

    let currentIndex = 0;

    function showSlide(nextIndex: number) {
      currentIndex = (nextIndex + slides.length) % slides.length;

      slides.forEach((slide, index) => {
        slide.classList.toggle("is-active", index === currentIndex);
      });

      if (indexLabel) {
        indexLabel.textContent = String(currentIndex + 1);
      }
    }

    previousButton?.addEventListener("click", () => {
      showSlide(currentIndex - 1);
    });

    nextButton?.addEventListener("click", () => {
      showSlide(currentIndex + 1);
    });

    showSlide(0);
  });

  document.querySelectorAll("[data-category-toggle]").forEach((button) => {
    const card = button.closest("[data-category-card]");
    const icon = button.querySelector(".category-card-icon");

    if (!card) return;

    button.addEventListener("click", () => {
      const isExpanded = card.classList.toggle("is-expanded");

      button.setAttribute("aria-expanded", String(isExpanded));

      if (icon) {
        icon.textContent = isExpanded ? "−" : "+";
      }
    });
  });
</script>
