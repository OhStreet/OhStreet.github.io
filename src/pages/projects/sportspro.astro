---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { Code } from "astro:components";

const sourceHref = "https://github.com/OhStreet/SportsPro-Technical-Support"

const sportsProCode = `[HttpGet]
[Route("Incidents")]
public ViewResult List(IncidentListViewModel model)
{
    IQueryable<Incident> query = context.Incidents
        .Include(i => i.Customer)
        .Include(i => i.Product)
        .Include(i => i.Technician);

    if (model.IncidentStatus == "unassigned")
    {
        query = query.Where(i => i.TechnicianID == -1);
    }
    else if (model.IncidentStatus == "open")
    {
        query = query.Where(i => i.DateClosed == null);
    }

    model.Incidents = query.OrderBy(i => i.DateOpened).ToList();

    return View(model);
}`;

const techStack = [
  "C#",
  "ASP.NET Core MVC",
  "Entity Framework Core",
  "SQL Server",
  "Razor Views",
  "Bootstrap",
];

const features = [
  "Product, customer, technician, and incident management",
  "List, add, edit, and delete workflows using MVC controllers and Razor views",
  "Incident filtering by status, including open and unassigned incidents",
  "Entity Framework Core database access with related customer, product, and technician data",
  "View models used to pass filtered data into Razor views",
  "Server-side validation for required fields, string lengths, ranges, and dates",
  "Initial database migration and seed data for core support records",
  "Bootstrap-based layout for consistent page structure",
];

const screenshots = [
  {
    src: "/screenshots/sportspro-home.png",
    alt: "SportsPro home page",
    title: "Home Page",
    caption: "Landing page for the SportsPro technical support application.",
  },
  {
    src: "/screenshots/sportspro-incidents.png",
    alt: "SportsPro incident list with filters",
    title: "Incident List and Filters",
    caption:
      "Incident list showing related customer, product, technician, and status information.",
  },
  {
    src: "/screenshots/sportspro-technician-incidents.png",
    alt: "SportsPro technician incident workflow",
    title: "Technician Incident Workflow",
    caption:
      "Technician-specific workflow for selecting a technician and updating assigned incidents.",
  },
];
---

<BaseLayout
  title="SportsPro Technical Support | Jared Street"
  description="ASP.NET Core MVC support management system with database-backed CRUD workflows."
>
  <section class="page-hero project-hero fade-in">
    <p class="eyebrow">C# / ASP.NET Core</p>
    <h1>SportsPro Technical Support</h1>
    <p>
      A database-backed ASP.NET Core MVC application for managing technical support
      records, including products, customers, technicians, and incidents.
    </p>

    <div class="tech-list">
      {techStack.map((tech) => <span class="tech-pill">{tech}</span>)}
    </div>

    <div class="button-row">
      <a class="button button-secondary" href="/projects/">Back to Projects</a>
      {sourceHref && (
        <a
          class="button button-primary"
          href={sourceHref}
          target="_blank"
          rel="noopener noreferrer"
        >
          View Source
        </a>
      )}
    </div>
  </section>

  <section class="section-card project-section fade-in">
    <p class="eyebrow">Overview</p>
    <h2>Project Purpose</h2>
    <p>
      SportsPro Technical Support is an ASP.NET Core MVC application built around
      a practical support-desk workflow. The system allows users to maintain
      product, customer, technician, and incident records through standard
      database-backed CRUD operations.
    </p>
    <p>
      The project demonstrates core application-development patterns: MVC routing,
      controller actions, Razor views, Entity Framework Core queries, model
      validation, relational data, and view models used to organize page-specific
      data.
    </p>
  </section>

  <section class="section-card project-section fade-in">
    <p class="eyebrow">Features</p>
    <h2>What the Application Does</h2>

    <ul class="feature-list">
      {features.map((feature) => <li>{feature}</li>)}
    </ul>
  </section>

  <section class="section-card project-section fade-in">
    <p class="eyebrow">Code Sample</p>
    <h2>Filtering Incidents with Entity Framework</h2>
    <p>
      This controller action builds an Entity Framework query, includes related
      records needed by the view, applies filtering logic, and returns the
      populated view model to the Razor page.
    </p>

    <Code code={sportsProCode} lang="csharp" theme="github-dark" wrap />

    <p>
      The important pattern here is separation of responsibilities: the controller
      prepares the data, Entity Framework handles the database query, and the
      Razor view focuses on presentation.
    </p>
  </section>

  <section class="section-card project-section fade-in">
    <p class="eyebrow">Screenshots</p>
    <h2>Application Screens</h2>

    <div class="screenshot-grid">
      {screenshots.map((screenshot) => (
        <figure class="screenshot-card">
          <img src={screenshot.src} alt={screenshot.alt} />
          <figcaption>
            <strong>{screenshot.title}</strong>
            <span>{screenshot.caption}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </section>
</BaseLayout>