---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Jared Street | Entry-Level Software Developer",
  description = "Portfolio for Jared Street, an entry-level software developer focused on web, database, and application projects.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>

  <body>
    <Nav />

    <main class="site-main">
      <slot />
    </main>

    <Footer />
  </body>
</html>